# Firebase Client Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=priv-lab
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (service account JSON path or inline key)
FIREBASE_ADMIN_PROJECT_ID=priv-lab
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Google Cloud Storage
GCS_BUCKET_NAME=stuffy-uploads

# Google Vertex AI
# Reuses FIREBASE_ADMIN_* credentials by default if separate Vertex credentials are not set.
GOOGLE_VERTEX_PROJECT=priv-lab
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_FLASH_MODEL=gemini-2.5-flash
GOOGLE_VERTEX_MULTIMODAL_EMBEDDING_MODEL=multimodalembedding@001
GOOGLE_VERTEX_MULTIMODAL_EMBEDDING_DIMENSIONS=512

# Auth allowlist (comma-separated emails)
ALLOWED_EMAILS=jimmy.stridh@gmail.com
NEXT_PUBLIC_ALLOWED_EMAILS=jimmy.stridh@gmail.com

# Cloud Run URL (set after first deploy)
NEXTAUTH_URL=http://localhost:3000
